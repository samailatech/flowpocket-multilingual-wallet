{
  "name": "digital-wallet-p2p-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "db:start": "docker compose up -d postgres",
    "db:init": "sh -c 'docker exec -i digital-wallet-postgres psql -U wallet -d digital_wallet < packages/db/schema.sql'",
    "db:stop": "docker compose down",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:api": "npm --workspace services/api run dev",
    "build:web": "npm --workspace apps/web run build",
    "start:api": "npm --workspace services/api run start"
  }
}
